## 5. Autenticación Segura — JWT y bcrypt

### 5.1 JWT — Configuración Obligatoria

```typescript
// infrastructure/auth/jwt.service.ts
const JWT_CONFIG = {
  algorithm: 'HS256' as const,  // Adecuado para monolito on-premise
  expiresIn: '8h',              // NFR-006: máximo 8 horas — PRD-US-018
  issuer: 'sgai-universidad',   // Identificador del emisor
} as const;

// Payload del JWT — campos permitidos (NUNCA incluir PII)
interface JwtPayload {
  userId: string;      // UUID del usuario
  email: string;       // email institucional (no es PII financiero)
  rol: Rol;            // enum de roles
  facultadId: string;  // UUID de la facultad
  iat: number;         // issued at (automático)
  exp: number;         // expiration (automático)
  // ❌ NUNCA incluir: password, ci, haber_basico, telefono
}

// Almacenamiento del JWT en el cliente
// ✅ Memoria del frontend (variable React state)
// ✅ httpOnly cookie con Secure + SameSite=Strict
// ❌ localStorage — vulnerable a XSS
// ❌ sessionStorage — no persiste entre pestañas, pero igual vulnerable a XSS
```

### 5.2 bcrypt — Hashing de Contraseñas

```typescript
// infrastructure/auth/password.service.ts
const BCRYPT_COST_FACTOR = 12; // Mínimo 12 — NUNCA bajar este valor

async function hashPassword(plaintext: string): Promise<string> {
  // ✅ Nunca loggear el plaintext ni el hash
  return bcrypt.hash(plaintext, BCRYPT_COST_FACTOR);
}

async function verifyPassword(plaintext: string, hash: string): Promise<boolean> {
  return bcrypt.compare(plaintext, hash);
  // ✅ bcrypt.compare es timing-safe — previene timing attacks
}

// ❌ NUNCA usar:
// MD5, SHA1, SHA256 sin salt — inseguros
// SHA256 con salt fijo — vulnerable a rainbow tables
// Costo factor < 12 — demasiado rápido para ataques de fuerza bruta
```

### 5.3 Bloqueo de Cuenta — RB-07

```typescript
// MUST implementar en el servicio de autenticación
const MAX_FAILED_ATTEMPTS = 5;
const BLOCK_DURATION_MINUTES = 15;

async function verificarBloqueoCuenta(usuario: Usuario): Promise<void> {
  if (usuario.bloqueado_hasta && usuario.bloqueado_hasta > new Date()) {
    const tiempoRestante = Math.ceil(
      (usuario.bloqueado_hasta.getTime() - Date.now()) / 60000
    );
    throw new UnauthorizedError('ACCOUNT_TEMPORARILY_BLOCKED');
    // La respuesta HTTP debe incluir: desbloqueo_en: usuario.bloqueado_hasta.toISOString()
  }
}

async function registrarIntentoFallido(usuarioId: string): Promise<void> {
  // Incrementar y verificar si debe bloquear — en la MISMA transacción
  await prisma.$transaction(async (tx) => {
    const usuario = await tx.usuario.update({
      where: { id: usuarioId },
      data: { intentos_fallidos: { increment: 1 } },
      select: { intentos_fallidos: true },
    });
    if (usuario.intentos_fallidos >= MAX_FAILED_ATTEMPTS) {
      await tx.usuario.update({
        where: { id: usuarioId },
        data: {
          bloqueado_hasta: new Date(Date.now() + BLOCK_DURATION_MINUTES * 60 * 1000),
        },
      });
    }
  });
}
```

