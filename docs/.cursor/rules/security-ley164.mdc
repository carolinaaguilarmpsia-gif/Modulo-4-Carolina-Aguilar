## 10. Rate Limiting y Protección Anti-Fuerza Bruta

```typescript
// api/middleware/rateLimiting.middleware.ts
import rateLimit from 'express-rate-limit';

// Rate limiting para endpoints de autenticación — OBLIGATORIO
export const authRateLimit = rateLimit({
  windowMs: 15 * 60 * 1000,  // 15 minutos
  max: 20,                    // máximo 20 intentos por IP en 15 min
  message: {
    error: 'RATE_LIMIT_EXCEEDED',
    message: 'Demasiados intentos de acceso. Intente nuevamente en 15 minutos.',
  },
  standardHeaders: true,
  legacyHeaders: false,
  skip: (req) => process.env.NODE_ENV === 'test', // skip en tests
});

// Rate limiting para generación de reportes (evitar DoS)
export const reportRateLimit = rateLimit({
  windowMs: 60 * 1000,   // 1 minuto
  max: 5,                // máximo 5 reportes por minuto por usuario
  keyGenerator: (req) => req.user?.userId ?? req.ip, // por usuario, no por IP
});

// Uso en router:
router.post('/auth/login', authRateLimit, authController.login);
router.post('/reportes', authenticate, reportRateLimit, reportController.generate);
```

