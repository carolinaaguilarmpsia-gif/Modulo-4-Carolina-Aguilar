## 12. Manejo de Errores — Sin Exponer Internos en Producción

```typescript
// api/middleware/errorHandler.middleware.ts
import { DomainError } from '@domain/shared/errors/DomainError';

export function globalErrorHandler(
  err: Error,
  req: Request,
  res: Response,
  _next: NextFunction
): void {
  const correlationId = req.correlationId ?? 'unknown';

  if (err instanceof DomainError) {
    // Error de dominio conocido — retornar código y mensaje para el usuario
    logger.warn('Domain error', {
      correlationId,
      errorCode: err.code,
      httpStatus: err.httpStatus,
      // NO loggear err.context si contiene PII
    });
    res.status(err.httpStatus).json({
      error: err.code,
      message: err.message,   // mensaje en español boliviano
      correlationId,
    });
    return;
  }

  // Error inesperado — loggear internamente, responder genéricamente
  logger.error('Unhandled error', {
    correlationId,
    errorType: err.constructor.name,
    // err.message: loggear solo si no contiene PII
    // err.stack: NUNCA en producción en la respuesta
  });

  res.status(500).json({
    error: 'INTERNAL_ERROR',
    correlationId,
    // NADA MÁS — ni message, ni stack, ni query SQL
  });
}
```

