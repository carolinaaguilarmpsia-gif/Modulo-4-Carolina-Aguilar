## 4. Validación de Acceso a Datos Personales (RB-04)

**MUST** incluir esta verificación en TODO endpoint que retorne datos de un docente específico.

```typescript
// helpers/assertOwnData.ts
function assertOwnData(
  req: AuthenticatedRequest,
  targetDocenteId: string,
  correlationId: string
): void {
  if (req.user.rol === Rol.DOCENTE && req.user.userId !== targetDocenteId) {
    // Log de auditoría del intento de acceso no autorizado
    logger.warn('Unauthorized data access attempt', {
      correlationId,
      accessorId: req.user.userId,
      accessorRol: req.user.rol,
      targetResourceId: targetDocenteId,
      resourceType: 'DOCENTE_DATA',
      timestamp: new Date().toISOString(),
    });
    throw new ForbiddenError('UNAUTHORIZED_DATA_ACCESS'); // HTTP 403 — RB-04 / Ley 164
  }
}

// Uso obligatorio en controladores de datos personales:
app.get('/boletas-pago', authenticate, (req, res) => {
  const docenteId = req.user.userId; // SIEMPRE del JWT — NUNCA de req.params
  assertOwnData(req, docenteId, req.correlationId); // PRIMERA línea antes de cualquier lógica
  // ...
});
```

