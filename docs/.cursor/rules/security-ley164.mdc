## 8. Validación de Inputs — Siempre Antes del Dominio

**MUST** validar con Zod (o class-validator) en la capa de API **antes** de pasar cualquier dato al dominio. El dominio asume que los datos que recibe ya están validados y sanitizados.

```typescript
// api/controllers/dj.controller.ts
import { z } from 'zod';

// Schema de validación — definir en la capa api/, NO en domain/
const TransicionDJSchema = z.object({
  comando: z.enum(['ENVIAR', 'APROBAR', 'DEVOLVER', 'ESCALAR_DPA', 'REENVIAR', 'RECHAZAR']),
  observaciones: z.string().min(10).max(1000).optional(),
  // NUNCA incluir actorId en el body — viene del JWT
});

// Middleware de validación
function validateBody<T>(schema: z.ZodSchema<T>) {
  return (req: Request, res: Response, next: NextFunction) => {
    const result = schema.safeParse(req.body);
    if (!result.success) {
      return res.status(422).json({
        error: 'VALIDATION_ERROR',
        details: result.error.flatten(),
        correlationId: req.correlationId,
      });
    }
    req.validatedBody = result.data;
    next();
  };
}

// Uso:
router.patch('/declaraciones-juradas/:id/estado',
  authenticate,          // 1. Verificar JWT
  validateBody(TransicionDJSchema),  // 2. Validar input
  djController.transicionarEstado    // 3. Lógica de negocio
);
```

