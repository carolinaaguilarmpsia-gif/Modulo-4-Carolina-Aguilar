## 7. Jerarquía de Errores de Dominio

**MUST** usar errores tipados del dominio. NUNCA `throw new Error('string')` en código de dominio.

```typescript
// domain/shared/errors/DomainError.ts
abstract class DomainError extends Error {
  constructor(
    public readonly code: keyof typeof USER_MESSAGES_ES_BO,
    public readonly httpStatus: number,
    public readonly context?: Record<string, unknown>
  ) {
    super(USER_MESSAGES_ES_BO[code]);
  }
}

class ForbiddenError extends DomainError {
  constructor(code: keyof typeof USER_MESSAGES_ES_BO, ctx?: Record<string, unknown>) {
    super(code, 403, ctx);
  }
}

class NotFoundError extends DomainError {
  constructor(code: keyof typeof USER_MESSAGES_ES_BO) { super(code, 404); }
}

class ValidationError extends DomainError {
  constructor(code: keyof typeof USER_MESSAGES_ES_BO, ctx?: Record<string, unknown>) {
    super(code, 422, ctx);
  }
}

class UnauthorizedError extends DomainError {
  constructor(code: keyof typeof USER_MESSAGES_ES_BO) { super(code, 401); }
}

class ConflictError extends DomainError {
  constructor(code: keyof typeof USER_MESSAGES_ES_BO) { super(code, 409); }
}
```

